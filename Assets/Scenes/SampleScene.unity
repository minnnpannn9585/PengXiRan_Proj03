  m_Name: 
  m_EditorClassIdentifier: 
  dialogueText: {fileID: 901068562}
  nextButton: {fileID: 1849929615}
  dialogues:
  - "Player: Good morning. Lovely day today, isn\u2019t it?"
  - 'Emily: Good morning. The sunshine is absolutely lovely.'
  - 'Player: You look a bit pale, though. Are you feeling under the weather?'
  - "Emily: Oh, sort of. I slept terribly last night. I had horrific nightmares and
    woke up time and again. There was this cold draft drifting in now and then, even
    though I\u2019d shut all the windows before bed. It was really odd."
  - "Player: I see\u2026 Don\u2019t fret. I\u2019ll give you some soothing herbs.
    They\u2019ll help settle your nerves."
  - 'Emily: Thank you so much!'
  - "Player: It\u2019s no trouble. I\u2019ll bring the herbs to you this evening."
